    <command:details>
      <command:name>Get-VHDXProfileSize</command:name>
      <command:verb>Get</command:verb>
      <command:noun>VHDXProfileSize</command:noun>
      <maml:description>
        <maml:para>retrieve profile size</maml:para>
      </maml:description>
    </command:details>
    <maml:description>
      <maml:para>This function is used to retrieve the size of a user's vhdx file. This vhdx file is the person's RDS profile</maml:para>
    </maml:description>
    <command:syntax>
      <command:syntaxItem>
        <maml:name>Get-VHDXProfileSize</maml:name>
        <command:parameter required="false" variableLength="true" globbing="false" pipelineInput="False" position="1" aliases="none">
          <maml:name>GivenName</maml:name>
          <maml:Description>
            <maml:para>User first name</maml:para>
          </maml:Description>
          <command:parameterValue required="true" variableLength="false">String</command:parameterValue>
          <dev:type>
            <maml:name>String</maml:name>
            <maml:uri />
          </dev:type>
          <dev:defaultValue>None</dev:defaultValue>
        </command:parameter>
        <command:parameter required="false" variableLength="true" globbing="false" pipelineInput="False" position="2" aliases="none">
          <maml:name>SurName</maml:name>
          <maml:Description>
            <maml:para>User last name</maml:para>
          </maml:Description>
          <command:parameterValue required="true" variableLength="false">String</command:parameterValue>
          <dev:type>
            <maml:name>String</maml:name>
            <maml:uri />
          </dev:type>
          <dev:defaultValue>None</dev:defaultValue>
        </command:parameter>
        <command:parameter required="false" variableLength="true" globbing="false" pipelineInput="False" position="3" aliases="none">
          <maml:name>Company</maml:name>
          <maml:Description>
            <maml:para>{{ Fill Company Description }}</maml:para>
          </maml:Description>
          <command:parameterValue required="true" variableLength="false">String</command:parameterValue>
          <dev:type>
            <maml:name>String</maml:name>
            <maml:uri />
          </dev:type>
          <dev:defaultValue>None</dev:defaultValue>
        </command:parameter>
        <command:parameter required="false" variableLength="true" globbing="false" pipelineInput="False" position="4" aliases="none">
          <maml:name>ProfilePath</maml:name>
          <maml:Description>
            <maml:para>Path in which profiles are stored</maml:para>
          </maml:Description>
          <command:parameterValue required="true" variableLength="false">String</command:parameterValue>
          <dev:type>
            <maml:name>String</maml:name>
            <maml:uri />
          </dev:type>
          <dev:defaultValue>\\srv-profils01\upd$</dev:defaultValue>
        </command:parameter>
